# Application
APP_ENV=development
APP_SECRET_KEY=changeme-secret-key-at-least-32-chars
APP_DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/smart_career_roadmap

# JWT
JWT_SECRET_KEY=changeme-jwt-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
AI_TIMEOUT_SECONDS=60

# CORS
CORS_ORIGINS=http://localhost:3000
